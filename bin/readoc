#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# dependencies = [
#     "python-docx",
#     "openpyxl",
#     "pymupdf",
# ]
# ///
"""Read .docx, .xlsx, and .pdf files and output their content as plain text.

When multiple files are given (or always, for clarity), each file's content is
prefixed with an unambiguous header box showing its path, type, and size — the
same convention used by `readir read`, so concatenated output is never confusing.
"""

import sys
import os

# Comment extractors and the structure-aware search (used by `readoc search`)
# live in a sibling module shared with readir. realpath() resolves the PATH /
# skills symlinks back to the real bin/ directory so the import works in every
# launch mode (direct, symlinked, or under uv). The print-style readers below
# are readoc-specific and stay here so the normal read path is untouched.
sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from _readlib import (  # noqa: E402
    human_size,
    docx_comments,
    xlsx_comments,
    pdf_comments,
    READABLE_ALL,
    resolve_context,
    search_file,
)

TYPE_LABELS = {".docx": "Word", ".xlsx": "Excel", ".pdf": "PDF"}


def print_header(path, ext, size):
    label = TYPE_LABELS.get(ext, ext.lstrip(".").upper() or "file")
    print("═" * 60)
    print(f"  {path} ({label}, {human_size(size)})")
    print("═" * 60)
    print()


def print_comments(comments):
    """Print a trailing Comments section, but only when there are comments."""
    if not comments:
        return
    print("\n--- Comments ---")
    for line in comments:
        print(line)


def read_pdf(path, include_comments=True):
    import fitz  # PyMuPDF

    doc = fitz.open(path)
    for page_num, page in enumerate(doc, 1):
        text = page.get_text().strip()
        if text:
            if len(doc) > 1:
                print(f"\n--- Page {page_num} ---\n")
            print(text)
    if include_comments:
        print_comments(pdf_comments(doc))
    doc.close()


def read_docx(path, include_comments=True):
    from docx import Document

    doc = Document(path)

    for para in doc.paragraphs:
        text = para.text.strip()
        if text:
            if para.style and para.style.name.startswith("Heading"):
                level = para.style.name.replace("Heading ", "").strip()
                try:
                    prefix = "#" * int(level) + " "
                except ValueError:
                    prefix = "# "
                print(f"{prefix}{text}")
            else:
                print(text)

    if doc.tables:
        for i, table in enumerate(doc.tables):
            print(f"\n--- Table {i + 1} ---")
            for row in table.rows:
                cells = [cell.text.strip() for cell in row.cells]
                print(" | ".join(cells))

    if include_comments:
        print_comments(docx_comments(doc))


def read_xlsx(path, include_comments=True):
    from openpyxl import load_workbook

    wb = load_workbook(path, read_only=True, data_only=True)

    for sheet_name in wb.sheetnames:
        ws = wb[sheet_name]
        print(f"=== Sheet: {sheet_name} ===\n")

        rows = list(ws.iter_rows(values_only=True))
        if not rows:
            print("(empty sheet)\n")
            continue

        str_rows = []
        for row in rows:
            str_rows.append([str(cell) if cell is not None else "" for cell in row])

        col_widths = []
        for col_idx in range(len(str_rows[0])):
            max_width = 0
            for row in str_rows:
                if col_idx < len(row):
                    max_width = max(max_width, len(row[col_idx]))
            # Cap the *padding* width for readability, but never truncate content.
            col_widths.append(min(max_width, 40))

        for row_idx, row in enumerate(str_rows):
            padded = []
            for col_idx, cell in enumerate(row):
                width = col_widths[col_idx] if col_idx < len(col_widths) else 10
                # ljust pads short cells for alignment; long cells overflow in full (no truncation).
                padded.append(cell.ljust(width))
            print(" | ".join(padded))

            if row_idx == 0:
                print("-+-".join("-" * w for w in col_widths))

        print()

    wb.close()

    if include_comments:
        print_comments(xlsx_comments(path))


READERS = {".docx": read_docx, ".xlsx": read_xlsx, ".pdf": read_pdf}


def cmd_search(argv):
    import argparse

    parser = argparse.ArgumentParser(
        prog="readoc search",
        description="Search a single document (structure-aware context).",
    )
    parser.add_argument("file", help="Document to search (.docx/.xlsx/.pdf/.md/...)")
    parser.add_argument("query", help="Text to search for (case-insensitive)")
    ctx = parser.add_mutually_exclusive_group()
    ctx.add_argument(
        "--context",
        type=int,
        default=None,
        help="Lines of context around prose matches (default: 2)",
    )
    ctx.add_argument(
        "--context-paragraphs",
        type=int,
        default=None,
        help="Whole paragraphs of context around prose matches",
    )
    ctx.add_argument(
        "--context-chars",
        type=int,
        default=None,
        help="Characters of context on each side of prose matches",
    )
    parser.add_argument(
        "--context-rows",
        type=int,
        default=2,
        help="Rows of context around spreadsheet matches (default: 2)",
    )
    parser.add_argument(
        "--no-comments",
        action="store_true",
        help="Don't search document comments (searched by default)",
    )
    args = parser.parse_args(argv)

    if not os.path.exists(args.file):
        print(f"Error: File not found: {args.file}", file=sys.stderr)
        sys.exit(1)
    ext = os.path.splitext(args.file)[1].lower()
    if ext not in READABLE_ALL:
        print(f"Error: Unsupported file type '{ext}' for {args.file}", file=sys.stderr)
        print(f"Supported: {' '.join(sorted(READABLE_ALL))}", file=sys.stderr)
        sys.exit(1)

    mode, n = resolve_context(args)
    total = search_file(
        args.file,
        args.file,
        ext,
        args.query,
        mode,
        n,
        args.context_rows,
        not args.no_comments,
    )
    if total == 0:
        print(f"  No matches found for '{args.query}'")
    sys.exit(0)


def main():
    # `readoc search <file> <query> [...]` runs the single-file search path; any
    # other invocation is the normal reader. (A file literally named "search"
    # can still be read via `readoc ./search`.)
    if len(sys.argv) >= 2 and sys.argv[1] == "search":
        cmd_search(sys.argv[2:])
        return

    # Lightweight flag handling: comments are included by default; --no-comments
    # turns them off. --comments is accepted as a harmless explicit opt-in.
    include_comments = True
    files = []
    for arg in sys.argv[1:]:
        if arg == "--no-comments":
            include_comments = False
        elif arg == "--comments":
            include_comments = True
        else:
            files.append(arg)

    if not files:
        print(
            "Usage: readoc [--no-comments] <file.docx|file.xlsx|file.pdf> [file2 ...]"
        )
        print("       readoc search <file> <query> [--context-paragraphs N |")
        print("                                      --context-chars N | --context N]")
        print(
            "\nReads .docx, .xlsx, and .pdf files and outputs their content as plain text."
        )
        print("Each file is preceded by a header box (path, type, size).")
        print(
            "Document comments are included by default; pass --no-comments to omit them."
        )
        print("`readoc search` greps one file: paragraph/char context for prose, or")
        print("cell-coordinate + header context for spreadsheets (.xlsx).")
        sys.exit(1)

    exit_code = 0
    for filepath in files:
        if not os.path.exists(filepath):
            print(f"Error: File not found: {filepath}", file=sys.stderr)
            exit_code = 1
            continue

        ext = os.path.splitext(filepath)[1].lower()
        if ext not in READERS:
            print(
                f"Error: Unsupported file type '{ext}' for {filepath}", file=sys.stderr
            )
            print("Supported: .docx, .xlsx, .pdf", file=sys.stderr)
            exit_code = 1
            continue

        try:
            size = os.path.getsize(filepath)
        except OSError:
            size = 0

        print_header(filepath, ext, size)
        READERS[ext](filepath, include_comments)
        print()

    sys.exit(exit_code)


if __name__ == "__main__":
    main()
