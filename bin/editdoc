#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# dependencies = [
#     "python-docx",
#     "openpyxl",
# ]
# ///
"""Apply exact-match and structural edits to .docx and .xlsx files.

editdoc is to binary Office documents what Claude's built-in Edit tool is to
text files: it replaces *exact* strings, fails loudly when a match is missing or
ambiguous, and never half-applies a batch. The target file is given as an argv;
the edit(s) are a JSON spec read from stdin — a single object or an array of
objects, dispatched by which keys each carries:

  .docx in-paragraph replace : {"old_string", "new_string", "replace_all"?}
  .docx paragraph/range op   : {"start_contains", "end_contains"?, "new_text"}
  .xlsx cell edit            : {"sheet", "cell", "value"}

All edits are validated before any are applied, and the file is saved
crash-safely (temp file + atomic replace), so a failure leaves the original
byte-for-byte intact.
"""

import copy
import json
import os
import sys
import tempfile


SUPPORTED = {".docx", ".xlsx"}


class EditError(Exception):
    """A user-facing edit failure (bad match, ambiguity, invalid address …)."""


USAGE = (
    "Usage: editdoc <file.docx|file.xlsx>  < spec.json\n"
    "\n"
    "Reads a JSON edit spec (one object or an array of objects) from stdin and\n"
    "applies it to the file. Edit types are dispatched by their keys:\n"
    '  docx text replace : {"old_string": "...", "new_string": "...", "replace_all": false}\n'
    '  docx paragraph op : {"start_contains": "...", "end_contains": "...", "new_text": "..."}\n'
    '  xlsx cell edit    : {"sheet": "...", "cell": "B2", "value": "..."}\n'
)


def fail(message):
    print(message, file=sys.stderr)
    sys.exit(1)


def load_spec(raw):
    """Parse the stdin spec into a list of edit dicts, or raise EditError."""
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        raise EditError(f"Invalid JSON on stdin: {e}")
    if isinstance(data, dict):
        data = [data]
    if not isinstance(data, list):
        raise EditError("JSON spec must be an object or an array of objects.")
    for i, edit in enumerate(data):
        if not isinstance(edit, dict):
            raise EditError(f"edit {i + 1}: each edit must be a JSON object.")
    return data


# --- docx: paragraph traversal, rendering, run-level rewrite ---


def iter_doc_paragraphs(doc):
    """Yield (paragraph, location_label) for every editable paragraph in document
    order: body paragraphs first, then each top-level table cell's paragraphs.

    The label is human-facing only (used in success output)."""
    units = []
    for i, p in enumerate(doc.paragraphs, 1):
        units.append((p, f"paragraph {i} (body)"))
    for ti, table in enumerate(doc.tables, 1):
        seen = set()  # a merged cell shows up once per grid position it spans
        for ri, row in enumerate(table.rows, 1):
            for ci, cell in enumerate(row.cells, 1):
                if id(cell._tc) in seen:
                    continue
                seen.add(id(cell._tc))
                for p in cell.paragraphs:
                    units.append((p, f"table {ti}, row {ri}, col {ci}"))
    return units


def paragraph_text(paragraph):
    """Visible text of a paragraph, reconstructed from its runs (the surface a
    match is tested against)."""
    return "".join(r.text for r in paragraph.runs)


def ensure_rewritable(paragraph, index):
    """Refuse to rewrite a paragraph whose visible text isn't fully carried by
    its runs — e.g. it contains a hyperlink, field, or footnote reference whose
    runs are nested in a wrapper element and therefore invisible to
    ``paragraph.runs``. Rewriting such a paragraph would silently drop/scramble
    that content, so we fail loudly instead and leave the document untouched."""
    if paragraph.text != "".join(r.text for r in paragraph.runs):
        raise EditError(
            f"edit {index + 1}: paragraph contains content editdoc can't safely "
            "rewrite (e.g. a hyperlink, field, or footnote reference) — edit not "
            "applied to avoid corrupting it. Edit a different paragraph or adjust "
            "the document first."
        )


def render_paragraph_markdown(paragraph):
    """Render a paragraph as Markdown (bold/italic spans, heading prefix) so an
    edit's result can be eyeballed for formatting."""
    parts = []
    for r in paragraph.runs:
        t = r.text
        if not t:
            continue
        if r.italic:
            t = f"*{t}*"
        if r.bold:
            t = f"**{t}**"
        parts.append(t)
    text = "".join(parts)
    style = paragraph.style.name if paragraph.style else ""
    if style.startswith("Heading"):
        level = style.replace("Heading ", "").strip()
        try:
            prefix = "#" * int(level) + " "
        except ValueError:
            prefix = "# "
        return prefix + text
    return text


def find_all(haystack, needle):
    """Non-overlapping match start offsets of needle in haystack."""
    positions = []
    i = 0
    while True:
        j = haystack.find(needle, i)
        if j == -1:
            break
        positions.append(j)
        i = j + len(needle)
    return positions


def _copy_run_format(dst_run, src_run):
    """Copy character formatting (the run's rPr) from src_run onto dst_run."""
    from docx.oxml.ns import qn

    dst_el = dst_run._element
    existing = dst_el.find(qn("w:rPr"))
    if existing is not None:
        dst_el.remove(existing)
    src_rpr = src_run._element.find(qn("w:rPr"))
    if src_rpr is not None:
        dst_el.insert(0, copy.deepcopy(src_rpr))


def replace_in_paragraph(paragraph, old, new, positions):
    """Replace the matches of ``old`` at the given start ``positions`` with ``new``.

    Works at character granularity: every original character is tagged with its
    source run; replacement characters inherit the *first spanned run's* tag.
    The paragraph's runs are then rebuilt by grouping consecutive same-tag
    characters and copying each source run's formatting — so untouched text keeps
    its exact formatting and replacements take the first run's.
    """
    runs = list(paragraph.runs)
    # Tag each original character with its source run index.
    tags = []  # list of (char, run_index)
    for ri, r in enumerate(runs):
        for ch in r.text:
            tags.append((ch, ri))

    end_of = {pos: pos + len(old) for pos in positions}
    result = []  # rebuilt list of (char, run_index)
    cursor = 0
    for pos in sorted(positions):
        result.extend(tags[cursor:pos])
        first_run_idx = tags[pos][1] if pos < len(tags) else (len(runs) - 1)
        for ch in new:
            result.append((ch, first_run_idx))
        cursor = end_of[pos]
    result.extend(tags[cursor:])

    # Group consecutive characters sharing a source run into output segments.
    groups = []  # list of [text, run_index]
    for ch, idx in result:
        if groups and groups[-1][1] == idx:
            groups[-1][0] += ch
        else:
            groups.append([ch, idx])

    # Replace the paragraph's runs wholesale, restoring each segment's formatting.
    for r in runs:
        r._element.getparent().remove(r._element)
    for text, idx in groups:
        new_run = paragraph.add_run(text)
        if runs:
            _copy_run_format(new_run, runs[min(idx, len(runs) - 1)])


# --- docx: edit application ---


def apply_text_replace(doc, edit, index):
    old = edit.get("old_string")
    new = edit.get("new_string")
    if old is None or new is None:
        raise EditError(
            f"edit {index + 1}: a text replace needs both old_string and new_string."
        )
    if old == "":
        raise EditError(f"edit {index + 1}: old_string must not be empty.")
    if "\n" in old:
        raise EditError(
            f"edit {index + 1}: old_string spans a paragraph break (contains a "
            "newline). In-paragraph replace works within a single paragraph; use "
            "a paragraph op (start_contains/end_contains) for multi-paragraph edits."
        )
    replace_all = bool(edit.get("replace_all", False))

    hits = []  # (paragraph, label, positions)
    total = 0
    for para, label in iter_doc_paragraphs(doc):
        positions = find_all(paragraph_text(para), old)
        if positions:
            # Guard before collecting (hence before any mutation): a hit in a
            # hyperlink/field paragraph must abort the whole edit, not corrupt it.
            ensure_rewritable(para, index)
            hits.append((para, label, positions))
            total += len(positions)

    if total == 0:
        raise EditError(f'edit {index + 1}: old_string not found: "{old}"')
    if total > 1 and not replace_all:
        raise EditError(
            f'edit {index + 1}: old_string "{old}" matches {total} times — '
            "add surrounding context to make it unique, or set replace_all=true."
        )

    outputs = []
    for para, label, positions in hits:
        replace_in_paragraph(para, old, new, positions)
        n = len(positions)
        outputs.append(
            f"✓ edit {index + 1}: replaced {n} occurrence"
            f"{'' if n == 1 else 's'} in {label}"
        )
        outputs.append("  └ " + render_paragraph_markdown(para))
    return outputs


# --- docx: paragraph / range replace ---


def iter_doc_containers(doc):
    """Yield (container_id, ordered_paragraph_list) for each paragraph container:
    the body, then each top-level table cell. A paragraph range may not cross
    from one container into another."""
    containers = [("body", list(doc.paragraphs))]
    for ti, table in enumerate(doc.tables, 1):
        seen = set()  # a merged cell shows up once per grid position it spans
        for ri, row in enumerate(table.rows, 1):
            for ci, cell in enumerate(row.cells, 1):
                if id(cell._tc) in seen:
                    continue
                seen.add(id(cell._tc))
                containers.append(
                    (f"table {ti}, row {ri}, col {ci}", list(cell.paragraphs))
                )
    return containers


def locate_anchor(doc, substring, role, index):
    """Find the single paragraph whose visible text contains ``substring``.

    Returns (container_id, position_in_container). Raises EditError when the
    anchor is missing or matches more than one paragraph."""
    matches = []
    for cid, paras in iter_doc_containers(doc):
        for pos, para in enumerate(paras):
            if substring in paragraph_text(para):
                matches.append((cid, pos))
    if not matches:
        raise EditError(f'edit {index + 1}: {role} not found: "{substring}"')
    if len(matches) > 1:
        raise EditError(
            f'edit {index + 1}: {role} "{substring}" matches {len(matches)} '
            "paragraphs — add more context to make it unique."
        )
    return matches[0]


def set_paragraph_text(paragraph, text):
    """Replace all of a paragraph's runs with a single run holding ``text``,
    inheriting the formatting of the paragraph's original first run."""
    runs = list(paragraph.runs)
    fmt_src = runs[0] if runs else None
    for r in runs:
        r._element.getparent().remove(r._element)
    new_run = paragraph.add_run(text)
    if fmt_src is not None:
        _copy_run_format(new_run, fmt_src)


def insert_paragraph_after(paragraph, text):
    """Insert a new paragraph after ``paragraph``, cloning its paragraph
    properties (style/numbering) so the produced paragraph matches, and return it."""
    from docx.oxml.ns import qn
    from docx.text.paragraph import Paragraph

    new_p = copy.deepcopy(paragraph._p)
    # Strip the cloned content, keeping only the paragraph properties (w:pPr).
    for child in list(new_p):
        if child.tag != qn("w:pPr"):
            new_p.remove(child)
    paragraph._p.addnext(new_p)
    new_para = Paragraph(new_p, paragraph._parent)
    src_run = paragraph.runs[0] if paragraph.runs else None
    run = new_para.add_run(text)
    if src_run is not None:
        _copy_run_format(run, src_run)
    return new_para


def remove_paragraph(paragraph):
    paragraph._p.getparent().remove(paragraph._p)


def apply_paragraph_op(doc, edit, index):
    start = edit.get("start_contains")
    new_text = edit.get("new_text")
    if start is None or new_text is None:
        raise EditError(
            f"edit {index + 1}: a paragraph op needs start_contains and new_text."
        )
    if start == "":
        raise EditError(
            f"edit {index + 1}: start_contains must not be empty "
            "(an empty anchor matches every paragraph)."
        )
    end = edit.get("end_contains")
    if end == "":
        raise EditError(
            f"edit {index + 1}: end_contains must not be empty "
            "(an empty anchor matches every paragraph)."
        )

    start_cid, start_pos = locate_anchor(doc, start, "start_contains", index)
    if end is not None:
        end_cid, end_pos = locate_anchor(doc, end, "end_contains", index)
        if end_cid != start_cid:
            raise EditError(
                f"edit {index + 1}: start_contains and end_contains are in "
                f"different containers ({start_cid} vs {end_cid}); a range must "
                "stay within one container."
            )
        if end_pos < start_pos:
            raise EditError(
                f"edit {index + 1}: end_contains paragraph comes before "
                "start_contains — check the order of your anchors."
            )
    else:
        end_pos = start_pos

    # Re-fetch the container's paragraph list now that anchors are validated.
    paras = dict(iter_doc_containers(doc))[start_cid]
    block = paras[start_pos : end_pos + 1]
    lines = new_text.split("\n") if new_text != "" else []

    if not lines:
        for para in block:
            remove_paragraph(para)
        outputs = [
            f"✓ edit {index + 1}: deleted {len(block)} paragraph"
            f"{'' if len(block) == 1 else 's'} ({start_cid})"
        ]
        return outputs

    first = block[0]
    # Rewriting the first paragraph in place would scramble it if it carries a
    # hyperlink/field, so guard it. (Deleted paragraphs are removed whole and
    # need no guard.)
    ensure_rewritable(first, index)
    set_paragraph_text(first, lines[0])
    anchor = first
    for line in lines[1:]:
        anchor = insert_paragraph_after(anchor, line)
    for para in block[1:]:
        remove_paragraph(para)

    outputs = [
        f"✓ edit {index + 1}: replaced {len(block)} paragraph"
        f"{'' if len(block) == 1 else 's'} → {len(lines)} ({start_cid})"
    ]
    # Preview: the first paragraph rendered with its (inherited) formatting, then
    # the additional split lines as plain text.
    outputs.append("  └ " + render_paragraph_markdown(first))
    outputs.extend("  └ " + line for line in lines[1:])
    return outputs


def apply_one_docx_edit(doc, edit, index):
    if "old_string" in edit:
        return apply_text_replace(doc, edit, index)
    if "start_contains" in edit:
        return apply_paragraph_op(doc, edit, index)
    raise EditError(
        f"edit {index + 1}: unrecognized docx edit — expected old_string "
        "(text replace) or start_contains (paragraph op)."
    )


def save_atomic(save_fn, path):
    """Save via a temp file in the same directory, then atomically replace the
    target — a crash mid-save never corrupts the original."""
    directory = os.path.dirname(os.path.abspath(path))
    ext = os.path.splitext(path)[1]
    fd, tmp = tempfile.mkstemp(dir=directory, suffix=ext)
    os.close(fd)
    try:
        save_fn(tmp)
        os.replace(tmp, path)
    except Exception:
        if os.path.exists(tmp):
            os.remove(tmp)
        raise


def apply_docx_edits(path, edits):
    from docx import Document

    doc = Document(path)
    outputs = []
    for i, edit in enumerate(edits):
        outputs.extend(apply_one_docx_edit(doc, edit, i))
    # Reached only if every edit applied without raising; save once, atomically.
    save_atomic(doc.save, path)
    if outputs:
        print("\n".join(outputs))


# --- xlsx: cell edit ---


def coerce_value(value):
    """Coerce a JSON value for cell assignment: numeric-looking strings become
    int/float so spreadsheets get real numbers; everything else is left as-is."""
    if isinstance(value, str):
        try:
            return int(value)
        except ValueError:
            pass
        try:
            return float(value)
        except ValueError:
            pass
    return value


def apply_one_xlsx_edit(wb, edit, index):
    from openpyxl.utils.cell import coordinate_from_string

    sheet = edit.get("sheet")
    cell = edit.get("cell")
    if sheet is None or cell is None or "value" not in edit:
        raise EditError(f"edit {index + 1}: an xlsx edit needs sheet, cell, and value.")
    if sheet not in wb.sheetnames:
        available = ", ".join(wb.sheetnames)
        raise EditError(
            f"edit {index + 1}: sheet not found: {sheet!r} (available: {available})."
        )
    try:
        coordinate_from_string(cell)
    except Exception:
        raise EditError(
            f"edit {index + 1}: invalid cell coordinate: {cell!r} "
            "(expected a reference like B2)."
        )
    value = coerce_value(edit["value"])
    wb[sheet][cell] = value
    return [f"✓ edit {index + 1}: set {sheet}!{cell} = {value}"]


def apply_xlsx_edits(path, edits):
    from openpyxl import load_workbook

    wb = load_workbook(path)
    outputs = []
    for i, edit in enumerate(edits):
        if not isinstance(edit, dict) or "sheet" not in edit:
            raise EditError(
                f"edit {i + 1}: unrecognized xlsx edit — expected sheet/cell/value."
            )
        outputs.extend(apply_one_xlsx_edit(wb, edit, i))
    # Reached only if every edit validated; save once, atomically.
    save_atomic(wb.save, path)
    if outputs:
        print("\n".join(outputs))


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    files = [a for a in argv if not a.startswith("-")]

    if not files:
        print(USAGE)
        sys.exit(1)

    if len(files) > 1:
        fail(
            "Error: editdoc edits a single file at a time; got "
            f"{len(files)}: {', '.join(files)}"
        )

    filepath = files[0]
    if not os.path.exists(filepath):
        fail(f"Error: File not found: {filepath}")

    ext = os.path.splitext(filepath)[1].lower()
    if ext not in SUPPORTED:
        fail(
            f"Error: Unsupported file type '{ext}' for {filepath}\n"
            "Supported: .docx, .xlsx"
        )

    raw = sys.stdin.read()
    try:
        edits = load_spec(raw)
    except EditError as e:
        fail(f"Error: {e}")

    if not edits:
        # A valid no-op: nothing to do, file left untouched.
        sys.exit(0)

    try:
        if ext == ".docx":
            apply_docx_edits(filepath, edits)
        else:
            apply_xlsx_edits(filepath, edits)
    except EditError as e:
        fail(str(e))


if __name__ == "__main__":
    main()
